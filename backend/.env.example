# Copy to `.env` and fill in values. The app reads `backend/.env` only — not this file.

HOST=127.0.0.1
PORT=5000

MONGODB_URI=mongodb://127.0.0.1:27017/ngo

JWT_SECRET=

# Same origin as the frontend (scheme + host + port)
CLIENT_ORIGIN=http://localhost:5173

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# If set, this email receives admin role on register and existing users are promoted on server start.
# INITIAL_ADMIN_EMAIL=you@example.com
